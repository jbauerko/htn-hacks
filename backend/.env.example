ANTHROPIC_API_KEY=your_key_here
CORS_ORIGINS=http://localhost:3000

# Slack channel reminder (optional — only needed for POST /reminders/send)
# Create an incoming webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Minimum accuracy (0.0–1.0) for a module to count as "completed"
COMPLETION_MIN_ACCURACY=0.70

# URL shown at the bottom of the Slack reminder message
TRAINING_URL=http://localhost:3000
